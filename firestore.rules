rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if the authenticated user is the specific admin email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'adityasonofashok@gmail.com';
    }

    // Check if the user is accessing their own data
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- Collections ---

    // Users Collection
    match /users/{userId} {
      // 1. READ: Users can read their own profile. Admin can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // 2. CREATE: Users can create their own profile ONLY if 'isPro' is false.
      // This prevents users from hacking the client to create a Pro account.
      allow create: if isOwner(userId) && request.resource.data.isPro == false;
      
      // 3. UPDATE: ONLY Admin can update user profiles (e.g., granting Pro status).
      // Regular users do not update their root profile document in this app.
      allow update: if isAdmin();
      
      // 4. DELETE: Only Admin can delete users.
      allow delete: if isAdmin();

      // Sessions Subcollection (User managed)
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      // Progress Subcollection (User managed)
      match /progress/{progressId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Settings Collection (Pricing, Config)
    match /settings/{document} {
      // Authenticated users can read settings (e.g. to see price)
      allow read: if request.auth != null;
      // Only admin can modify settings
      allow write: if isAdmin();
    }
    
    // Feedback Collection
    match /feedback/{feedbackId} {
      // Anyone (authenticated or anonymous) can submit feedback
      allow create: if true;
      // Only admin can read feedback logs
      allow read: if isAdmin();
    }
    
    // Stats Collection (Admin Analytics)
    match /stats/{document=**} {
      // Locked down to Admin only for security
      allow read, write: if isAdmin();
    }
  }
}
